options gen2
require daslib/daspkg

[export]
def package() {
    package_name("dasImguiNodeEditor")
    package_description("imgui-node-editor bindings for daslang")
    package_author("borisbat")
    package_license("MIT")
    package_tag("gui")
    package_tag("imgui")
}

[export]
def dependencies(version : string) {
    require_package("github.com/borisbat/dasImgui")
}

[export]
def build() {
    cmake_build()
}
