options gen2
require daslib/fio

[export]
def initialize(project_path : string) {
    if (das_is_dll_build()) {
        register_dynamic_module("{project_path}/dasModuleImguiNodeEditor.shared_module", "Module_dasIMGUI_NODE_EDITOR")
    }
    register_native_path("imgui", "imgui_node_editor_boost", "{project_path}/daslib/imgui_node_editor_boost.das")
    // Default-on lint — forbids raw imgui_node_editor::* in consumer code so the
    // wrappers (begin_create/begin_delete queue injection, node/pin/link,
    // selection, lifecycle) can't be bypassed. Bundled into boost_v2 below via
    // `require imgui/imgui_node_editor_lint public`. Per-file opt-out:
    // `options _allow_node_editor_native = true`.
    register_native_path("imgui", "imgui_node_editor_lint", "{project_path}/daslib/imgui_node_editor_lint.das")
    register_native_path("imgui", "imgui_node_editor_boost_v2", "{project_path}/daslib/imgui_node_editor_boost_v2.das")
    register_native_path("imgui", "imgui_node_editor_live", "{project_path}/daslib/imgui_node_editor_live.das")
    register_native_path("imgui", "imgui_node_editor_app", "{project_path}/daslib/imgui_node_editor_app.das")
    register_native_path("imgui", "imgui_node_editor_theme_daslang", "{project_path}/daslib/imgui_node_editor_theme_daslang.das")
}
