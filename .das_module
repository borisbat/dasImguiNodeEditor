options gen2
require fio

[export]
def initialize(project_path : string) {
    if (das_is_dll_build()) {
        register_dynamic_module("{project_path}/dasModuleImguiNodeEditor.shared_module", "Module_dasIMGUI_NODE_EDITOR")
    }
    register_native_path("imgui", "imgui_node_editor_boost", "{project_path}/daslib/imgui_node_editor_boost.das")
}
